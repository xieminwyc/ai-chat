{
  "name": "ai-chat-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "APP_ENV=local node scripts/env.mjs next dev",
    "dev:local": "APP_ENV=local node scripts/env.mjs next dev",
    "dev:test": "APP_ENV=test node scripts/env.mjs next dev",
    "dev:pro": "APP_ENV=production node scripts/env.mjs next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "prisma:generate": "APP_ENV=local node scripts/env.mjs prisma generate",
    "prisma:generate:test": "APP_ENV=test node scripts/env.mjs prisma generate",
    "prisma:generate:pro": "APP_ENV=production node scripts/env.mjs prisma generate",
    "prisma:migrate:deploy": "APP_ENV=local node scripts/env.mjs prisma migrate deploy",
    "prisma:migrate:deploy:test": "APP_ENV=test node scripts/env.mjs prisma migrate deploy",
    "prisma:migrate:deploy:pro": "APP_ENV=production node scripts/env.mjs prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dayjs": "^1.11.20",
    "next": "16.2.1",
    "openai": "^6.32.0",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
